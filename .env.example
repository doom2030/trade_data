APP_ENV=dev
COMPOSE_PROJECT_NAME=trade_data

DATABASE_URL=postgresql+psycopg://trade:change-me@postgres:5432/trade_data
POSTGRES_DB=trade_data
POSTGRES_USER=trade
POSTGRES_PASSWORD=change-me

API_HOST_PORT=18080
API_HOST_BIND=0.0.0.0
API_CONTAINER_PORT=18081
POSTGRES_HOST_PORT=15432

BAOSTOCK_PROVIDER=baostock
DEFAULT_HISTORY_END_DATE=
DEFAULT_HISTORY_START_DATE=2020-01-01
PERIODIC_FREQUENCIES=day,week,month
PERIODIC_ADJUST_FLAGS=none,forward,backward
DEFAULT_ADJUST_FLAG=forward
BACKFILL_PRIORITY=day,week,month

COLLECT_RETRY_TIMES=3
COLLECT_RETRY_SLEEP_SECONDS=3
COLLECT_BATCH_SIZE=2000
FAILED_JOB_RETRY_LIMIT=500
FAILED_JOB_MAX_ATTEMPTS=3
COLLECT_GLOBAL_LOCK_KEY=trade_data_baostock_collect
TRADE_CALENDAR_BENCHMARK_SYMBOLS=sh.600519,sh.600036,sh.601318,sh.601398,sz.000001,sz.000333,sz.000858,sz.002594,sz.300750,sz.300760,sh.688981,sh.688111
TRADE_CALENDAR_MIN_VALID_KLINES=3
CATCHUP_DAILY_MAX_TRADING_DAYS=15
MANUAL_BACKFILL_MAX_NATURAL_DAYS=15

API_MAX_KLINE_LIMIT=10000
PENDING_JOB_RUNNER_LIMIT=20
PENDING_JOB_STALE_MINUTES=60
DISK_USAGE_WARN_PERCENT=80
DISK_USAGE_CRITICAL_PERCENT=90

SECRET_KEY=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
SESSION_MAX_AGE_HOURS=72
